{
  "manifest_version": 3,
  "name": "Skool – Hide Leaderboard",
  "version": "1.3",
  "description": "Hides the leaderboard on Skool.",
  "permissions": ["declarativeContent", "storage"],
  "action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Skool – Hide Leaderboard",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.skool.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
