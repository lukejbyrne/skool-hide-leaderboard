{
  "manifest_version": 3,
  "name": "Skool – Open All Notifications",
  "version": "1.0",
  "description": "Opens every Skool notification in a new tab with one click.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://www.skool.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
